# Copy this file to .env and fill in your own values.
# Do not commit .env — it is in .gitignore.

# Required for AI report (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash-lite

# Optional: LADBS permit lookup (Socrata). Leave empty for anonymous requests.
SOCRATA_APP_TOKEN=

# Optional: Google Maps/Places for nearby home inspectors (name, rating, distance).
GOOGLE_MAPS_API_KEY=
